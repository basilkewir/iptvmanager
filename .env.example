# IPTV Manager — Configuration
# Copy to .env and edit

# Secret key for JWT (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# UDP Multicast output
UDP_MULTICAST_BASE=udp://239.0.0.1
UDP_MULTICAST_PORT_START=5000
UDP_TTL=16
UDP_BUFFER_SIZE=1316

# FFmpeg paths (Ubuntu default)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Health checking
HEALTH_CHECK_INTERVAL=5
HEALTH_CHECK_TIMEOUT=4
HEALTH_CHECK_FAILURES_BEFORE_DOWN=3

# DVR
DVR_STORAGE_PATH=./data/dvr
DVR_SEGMENT_DURATION=10
DVR_RETENTION_HOURS=2

# Logging
LOG_LEVEL=INFO
