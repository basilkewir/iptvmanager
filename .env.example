# IPTV Manager — Configuration
# Copy to .env and edit

# Secret key for JWT (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Flussonic RTMP target base URL
FLUSSONIC_RTMP_BASE=rtmp://localhost/live

# FFmpeg paths (Ubuntu default)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Health checking
HEALTH_CHECK_INTERVAL=5
HEALTH_CHECK_TIMEOUT=4
HEALTH_CHECK_FAILURES_BEFORE_DOWN=3

# DVR
DVR_STORAGE_PATH=./data/dvr
DVR_SEGMENT_DURATION=10
DVR_RETENTION_HOURS=24

# Logging
LOG_LEVEL=INFO
